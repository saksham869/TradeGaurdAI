# =============================================================================
# TradeGuard AI — Vercel Production Environment Variables
# Copy these keys into: Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit this file with real values. This is a template only.
# =============================================================================

# ── DATABASE (Required) ──────────────────────────────────────────────────────
# Use Neon (free): https://neon.tech → New Project → copy connection string
# Use Supabase: https://supabase.com → Settings → Database → Connection string
# The DATABASE_URL uses connection pooling (PgBouncer). DIRECT_URL is direct.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ── AI — PRIMARY (Required) ──────────────────────────────────────────────────
# OPTION A: Azure OpenAI (use your $100 student credit)
# portal.azure.com → Azure OpenAI → Deploy gpt-4o → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# OPTION B: GitHub Models (completely free, same API)
# github.com/settings/tokens → generate PAT (no scopes needed)
GITHUB_TOKEN=ghp_your_github_token
GITHUB_MODEL=gpt-4o

# ── AI — AZURE CONTENT SAFETY (Recommended for hackathon) ───────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=your-key

# ── REAL-TIME (Required for live updates) ───────────────────────────────────
# dashboard.pusher.com → free Sandbox plan (200k messages/day)
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=mt1
NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ── AUTH (Optional — app runs without Clerk in prototype mode) ───────────────
# dashboard.clerk.com → free tier
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_
CLERK_WEBHOOK_SECRET=whsec_

# ── CRON SECURITY (Required for cron jobs) ──────────────────────────────────
# Generate with: openssl rand -hex 32
# Add this SAME value to Vercel Dashboard AND to cron job config
CRON_SECRET=779a9dc6d8cac1ed5ece9677c85142c7d61551f4a71c1a641f25f9aa44cb2970

# ── CACHE (Optional — app works without Redis, caching is skipped) ───────────
# console.upstash.com → free tier → Create Database → copy REST URL + token
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── DATA PROVIDERS (Optional) ────────────────────────────────────────────────
# Yahoo Finance works without a key. These enable cron-based data ingestion.
POLYGON_API_KEY=           # polygon.io — news feed cron
ALPACA_API_KEY=            # alpaca.markets — broker webhooks
ALPACA_SECRET_KEY=
FMP_API_KEY=               # financialmodelingprep.com
STOCKTWITS_ACCESS_TOKEN=   # stocktwits.com — trending scan