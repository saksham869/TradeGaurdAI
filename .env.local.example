# =============================================================================
# TradeGuard AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# AUTH — Clerk (https://dashboard.clerk.com)
# Publishable key is safe to expose to the browser (NEXT_PUBLIC_).
# Secret key and webhook secret must stay server-side only.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
CLERK_WEBHOOK_SECRET=whsec_


# -----------------------------------------------------------------------------
# DATABASE — Supabase PostgreSQL (https://supabase.com/dashboard)
# DATABASE_URL  → pooled connection (used by Prisma at runtime)
# DIRECT_URL    → direct connection (used by Prisma for migrations)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres


# -----------------------------------------------------------------------------
# CACHE — Upstash Redis (https://console.upstash.com)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://[your-redis-id].upstash.io
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# REAL-TIME — Pusher (https://dashboard.pusher.com)
# PUSHER_KEY and PUSHER_CLUSTER are duplicated as NEXT_PUBLIC_ for the
# client-side Pusher connection — these are safe to expose to the browser.
# PUSHER_APP_ID and PUSHER_SECRET are server-side only.
# -----------------------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1


# -----------------------------------------------------------------------------
# MICROSOFT AZURE (https://portal.azure.com)
#
# Azure OpenAI — GPT-4o (deep research agent)
#   Endpoint:   Azure Portal → your OpenAI resource → Keys and Endpoint
#   API Key:    same page, Key 1 or Key 2
#   Deployment: Azure AI Studio → Deployments → your GPT-4o deployment name
#
# Azure Content Safety — journal guardian
#   Endpoint:   Azure Portal → your Content Safety resource → Keys and Endpoint
#   Key:        same page, Key 1 or Key 2
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

AZURE_CONTENT_SAFETY_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=


# -----------------------------------------------------------------------------
# AI MODELS
# -----------------------------------------------------------------------------

# Anthropic — Claude 3.5 Sonnet (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-

# xAI — Grok Beta (https://console.x.ai)
XAI_API_KEY=xai-

# Perplexity — Sonar Large (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-


# -----------------------------------------------------------------------------
# MARKET DATA
# -----------------------------------------------------------------------------

# Polygon.io — news ingestion, ticker data (https://polygon.io/dashboard)
POLYGON_API_KEY=

# Financial Modeling Prep — economic calendar, company profiles (https://financialmodelingprep.com/developer)
FMP_API_KEY=

# Alpaca Markets — real-time price bars (https://app.alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://data.alpaca.markets

# StockTwits — social trending stream (https://api.stocktwits.com)
# Optional — public endpoints work without a token, token increases rate limits
STOCKTWITS_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# CRON SECURITY
# Any random secret string — used as Bearer token to authenticate Vercel cron
# requests to /api/cron/* routes. Generate with: openssl rand -hex 32
# Must also be set in Vercel dashboard → Settings → Environment Variables.
# -----------------------------------------------------------------------------
CRON_SECRET=